APP_ENV=local
APP_NAME=Ontology Platform Backend
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://ontology:ontology@postgres:5432/ontology_platform
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DEV_USER_ID=dev-user
DEV_USER_NAME=Local Dev User
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=ontology
MINIO_SECRET_KEY=ontology-password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontology-password
LLM_PROVIDER=mock
LLM_API_KEY=
LOCAL_STORAGE_PATH=.local/storage

POSTGRES_DB=ontology_platform
POSTGRES_USER=ontology
POSTGRES_PASSWORD=ontology
MINIO_ROOT_USER=ontology
MINIO_ROOT_PASSWORD=ontology-password
NEO4J_AUTH=neo4j/ontology-password
