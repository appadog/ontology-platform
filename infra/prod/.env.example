# ---------------------------------------------------------------------------
# Production environment template. Copy to `.env` and fill real values.
# NEVER commit the real .env. On AWS, source secrets from SSM Parameter Store
# or Secrets Manager instead of a plaintext file.
# ---------------------------------------------------------------------------

# ===== Backend (FastAPI) =====
APP_ENV=production
APP_NAME=Ontology Platform Backend
API_V1_PREFIX=/api/v1

# DB connection. Bundled compose postgres (service name 'postgres'):
DATABASE_URL=postgresql+psycopg://ontology:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ontology_platform
# --- AWS RDS instead of bundled postgres (then remove the postgres service): ---
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@your-instance.abc123.ap-northeast-2.rds.amazonaws.com:5432/ontology_platform

# Allowed browser origins (JSON array). With the default same-origin nginx
# proxy the browser never makes a cross-origin call, but list your public
# domain(s) here for any direct API access / split-domain setup.
CORS_ORIGINS=["https://app.example.com"]

# Acting user identity for the current single-tenant/dev-actor model.
DEV_USER_ID=dev-user
DEV_USER_NAME=Prod User

# LLM provider. 'mock' uses deterministic fixtures (no external calls).
LLM_PROVIDER=mock
LLM_API_KEY=

# ===== Bundled postgres (compose only; ignored when using RDS) =====
POSTGRES_DB=ontology_platform
POSTGRES_USER=ontology
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===== Runtime =====
# uvicorn worker processes (rule of thumb: 2 x vCPU + 1).
WEB_CONCURRENCY=2
# Host port the frontend (nginx) is published on.
FRONTEND_PORT=80
